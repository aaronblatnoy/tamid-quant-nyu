# Copy to .env and fill in.  .env is gitignored — never commit secrets.

# ---------- Application ----------
APP_ENV=development                 # development | staging | production
LOG_LEVEL=INFO

# ---------- Database (Neon in prod, local docker postgres in dev) ----------
# Note: postgresql+psycopg:// (not postgresql://) so SQLAlchemy uses psycopg3.
DATABASE_URL=postgresql+psycopg://taq:taq@localhost:5432/taquantgeo

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- AIS — live ----------
# Get a free key at https://aisstream.io/
AISSTREAM_API_KEY=

# ---------- AIS — historical (Global Fishing Watch via BigQuery) ----------
# Path to the JSON service-account key for your GCP project.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-service-account.json
GCP_PROJECT_ID=

# ---------- Object storage (Cloudflare R2) ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=taquantgeo-archive
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# ---------- Equity prices ----------
# yfinance needs no key; Polygon is for production real-time.
POLYGON_API_KEY=

# ---------- Interactive Brokers (TWS or IB Gateway must be running) ----------
IBKR_HOST=127.0.0.1
IBKR_PORT=7497                      # 7497 paper, 7496 live
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=

# ---------- Risk limits — REQUIRED for live trading ----------
MAX_POSITION_USD=10000
MAX_GROSS_EXPOSURE_USD=50000
DAILY_LOSS_LIMIT_USD=2000
KILL_SWITCH=false                   # set true to block all new orders

# ---------- Notifications ----------
DISCORD_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1...
ALERT_PHONE=+1...

# ---------- Observability ----------
SENTRY_DSN=
